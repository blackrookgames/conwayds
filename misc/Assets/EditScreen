@var prefix game/assets/EditScreen
@var hdrpath ../../app/hdr/${prefix}.h
@var srcpath ../../app/src/${prefix}.cpp

@var hdrdef GAME_ASSETS_EDITSCREEN_H

@var namespace game::assets
@var class EditScreen

@load list data ./EditScreen.bin uint16 

@open ${hdrpath}
@line \#include <nds.h>
@line 
@line \#ifndef ${hdrdef}
@line \#define ${hdrdef}
@line 
@line namespace ${namespace}
@line {
@line     class ${class}
@line     {
@line         public:
@line         
@line         static const size_t size;
@line         static const u16 data[];
@line         
@line         static constexpr u8 coordx_x = 4;
@line         static constexpr u8 coordx_y = 20;
@line         static constexpr u8 coordy_x = 4;
@line         static constexpr u8 coordy_y = 21;
@line         static constexpr u8 zoom_x = 4;
@line         static constexpr u8 zoom_y = 22;
@line         static constexpr u8 tool_x = 31;
@line         static constexpr u8 tool_y = 23;
@line         static constexpr u8 live_x = 14;
@line         static constexpr u8 live_y = 2;
@line     };
@line }
@line 
@line \#endif
@close

@open ${srcpath}
@line \#include "${prefix}.h"
@line 
@line using namespace ${namespace};
@line 
@line const size_t ${class}::size = $(len data);
@line const u16 ${class}::data[] = 
@line $(cppdata data);
@close