@var prefix game/assets/MenuRandom
@var hdrpath ../../app/hdr/${prefix}.h
@var srcpath ../../app/src/${prefix}.cpp

@var hdrdef GAME_ASSETS_MENURANDOM_H

@var namespace game::assets
@var class MenuRandom

@load list data ./MenuRandom.bin uint16 

@open ${hdrpath}
@line \#include <nds.h>
@line 
@line \#ifndef ${hdrdef}
@line \#define ${hdrdef}
@line 
@line namespace ${namespace}
@line {
@line     class ${class}
@line     {
@line         public:
@line         
@line         static const size_t size;
@line         static const u16 data[];
@line         
@line         static constexpr u16 msg_x = 2;
@line         static constexpr u16 msg_y = 2;
@line         static constexpr u16 msg_w = 28;
@line         static constexpr u16 msg_h = 12;
@line         
@line         static constexpr u16 button_x = 2;
@line         static constexpr u16 button_y = 15;
@line         static constexpr u16 button_w = 14;
@line         static constexpr u16 button_h = 7;
@line         static constexpr u16 buttons = 2;
@line         static constexpr u16 columns = 2;
@line     };
@line }
@line 
@line \#endif
@close

@open ${srcpath}
@line \#include "${prefix}.h"
@line 
@line using namespace ${namespace};
@line 
@line const size_t ${class}::size = $(len data);
@line const u16 ${class}::data[] = 
@line $(cppdata data);
@close